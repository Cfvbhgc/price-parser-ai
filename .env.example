# ===== LLM (определение структуры прайса) =====
# Провайдер: deepseek (по умолчанию) или openai. Любой OpenAI-совместимый API.
LLM_PROVIDER=deepseek

# Ключ API. Без него инструмент всё равно работает — структура определяется
# эвристикой по ключевым словам (см. README).
LLM_API_KEY=replace_me

# Модель и base_url можно не указывать — подставятся дефолты провайдера.
# Для DeepSeek: deepseek-chat / https://api.deepseek.com
LLM_MODEL=
LLM_BASE_URL=
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=512

# ===== Разбор =====
# Файл категорий (ключевые слова → категория).
CATEGORIES_FILE=./categories.json
# Сколько строк-образцов отправлять в LLM (кроме заголовка).
SAMPLE_ROWS=5
# Сколько верхних строк просматривать при поиске заголовка.
HEADER_SCAN_LIMIT=25
